<AppLockerPolicy Version="1">
  <RuleCollection Type="Exe" EnforcementMode="Enabled">
    <FilePathRule Id="c83d9c3d-b420-5de1-a786-e3288dbc8b63"
                  Name="Permitir Administradores"
                  Description="Admins pueden ejecutar todo"
                  UserOrGroupSid="S-1-5-32-544" Action="Allow">
      <Conditions><FilePathCondition Path="*" /></Conditions>
    </FilePathRule>
    <FilePathRule Id="921cc481-6e17-4653-8f75-050b80acca20"
                  Name="Permitir Windows"
                  Description="Permitir ejecutables del sistema"
                  UserOrGroupSid="S-1-1-0" Action="Allow">
      <Conditions><FilePathCondition Path="%WINDIR%\*" /></Conditions>
    </FilePathRule>
    <FilePathRule Id="a61c8b2c-a319-4cd0-9690-d2177cad7b51"
                  Name="Permitir Program Files"
                  Description="Permitir ejecutables de Program Files"
                  UserOrGroupSid="S-1-1-0" Action="Allow">
      <Conditions><FilePathCondition Path="%PROGRAMFILES%\*" /></Conditions>
    </FilePathRule>
    <FilePathRule Id="f7cc97b6-1234-5678-abcd-5b59d52f95f8"
                  Name="BLOQUEAR notepad.exe por ruta"
                  Description="Bloquear notepad en System32"
                  UserOrGroupSid="S-1-5-21-2203628669-868486423-2365751758-1106" Action="Deny">
      <Conditions>
        <FilePathCondition Path="%WINDIR%\System32\notepad.exe" />
      </Conditions>
    </FilePathRule>
    <FileHashRule Id="c7dd97b6-4e3f-5f79-b31b-5b59d52f95f8"
                  Name="BLOQUEAR notepad renombrado a NoCuates"
                  Description="Bloquear notepad por hash aunque sea renombrado"
                  UserOrGroupSid="S-1-5-21-2203628669-868486423-2365751758-1106" Action="Deny">
      <Conditions>
        <FileHashCondition>
          <FileHash Type="SHA256"
                    Data="0xDA5807BB0997CC6B5132950EC87EDA2B33B1AC4533CF1F7A22A6F3B576ED7C5B"
                    SourceFileName="notepad.exe"
                    SourceFileLength="200704" />
        </FileHashCondition>
      </Conditions>
    </FileHashRule>
  </RuleCollection>
  <RuleCollection Type="Script" EnforcementMode="NotConfigured" />
  <RuleCollection Type="Msi" EnforcementMode="NotConfigured" />
  <RuleCollection Type="Dll" EnforcementMode="NotConfigured" />
  <RuleCollection Type="Appx" EnforcementMode="NotConfigured" />
</AppLockerPolicy>
